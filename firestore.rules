rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function userRole() {
      return signedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isRecruiter() {
      return userRole() == 'recruiter';
    }

    function ownsJob(jobId) {
      return signedIn()
        && isRecruiter()
        && get(/databases/$(database)/documents/jobs/$(jobId)).data.createdBy == request.auth.uid;
    }

    // Publicly readable open jobs.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if signedIn()
        && isRecruiter()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.status == 'open';
      allow update: if signedIn()
        && isRecruiter()
        && resource.data.createdBy == request.auth.uid
        && request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if signedIn()
        && isRecruiter()
        && resource.data.createdBy == request.auth.uid;
    }

    match /applications/{applicationId} {
      allow read: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || ownsJob(resource.data.jobId)
        );
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'submitted';
      allow update: if signedIn()
        && ownsJob(resource.data.jobId);
      allow delete: if signedIn()
        && (
          resource.data.userId == request.auth.uid
          || ownsJob(resource.data.jobId)
        );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isRecruiter();
      allow create: if isOwner(userId) && (request.resource.data.role == 'student' || request.resource.data.role == 'recruiter');
      allow update: if isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']));
      allow delete: if false;

      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }

      match /applications/{applicationId} {
        allow read: if isOwner(userId) || (signedIn() && ownsJob(resource.data.jobId));
        allow create: if isOwner(userId) && request.resource.data.status == 'submitted';
        allow update: if (isOwner(userId) && request.resource.data.status == resource.data.status && request.resource.data.jobId == resource.data.jobId)
          || (signedIn() && ownsJob(resource.data.jobId));
        allow delete: if isOwner(userId) || (signedIn() && ownsJob(resource.data.jobId));
      }

      match /cvs/{cvId} {
        allow read: if isOwner(userId) || isRecruiter();
        allow write: if isOwner(userId);
      }
    }
  }
}
